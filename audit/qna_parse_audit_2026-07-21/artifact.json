      "query": {
        "engine": "mysql + elasticsearch + docx",
        "sql": "SELECT d.*, kb.name AS kb_name, kb.tenant_id, kb.language AS kb_language FROM document d JOIN knowledgebase kb ON d.kb_id = kb.id WHERE d.parser_id = 'qa' AND d.status = '1' ORDER BY kb.name, d.name",
